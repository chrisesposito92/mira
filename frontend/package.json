		"shadcn-svelte": "^1.1.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"svelte-sonner": "^1.0.7",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lint": "^6.9.4",
		"@codemirror/state": "^6.5.4",
